# ==========================================
# GAMIFIED PLACEMENT PREP - ENV VARIABLES
# ==========================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/placement_prep_db"

# JWT Secrets
JWT_ACCESS_SECRET=your_super_secret_access_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# App URL (for email links)
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
